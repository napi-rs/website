{
  "$schema": "./node_modules/void/schema.json",
  "output": "server",
  "routing": {
    "redirects": {
      "/docs/": { "to": "/docs", "status": 301 },
      "/docs/*/": { "to": "/docs/:splat", "status": 301 },
      "/blog/": { "to": "/blog", "status": 301 },
      "/blog/*/": { "to": "/blog/:splat", "status": 301 },
      "/changelog/": { "to": "/changelog", "status": 301 },
      "/changelog/*/": { "to": "/changelog/:splat", "status": 301 }
    },
    "rewrites": {
      "/": "/en",
      "/docs/*": "/en/docs/:splat",
      "/blog/*": "/en/blog/:splat",
      "/changelog/*": "/en/changelog/:splat"
    },
    "revalidate": {
      "/changelog/*": 300
    },
    "headers": {
      "/": [
        "Cross-Origin-Opener-Policy: same-origin",
        "Cross-Origin-Embedder-Policy: require-corp"
      ],
      "/en": [
        "Cross-Origin-Opener-Policy: same-origin",
        "Cross-Origin-Embedder-Policy: require-corp"
      ],
      "/cn": [
        "Cross-Origin-Opener-Policy: same-origin",
        "Cross-Origin-Embedder-Policy: require-corp"
      ],
      "/pt-BR": [
        "Cross-Origin-Opener-Policy: same-origin",
        "Cross-Origin-Embedder-Policy: require-corp"
      ],
      "/assets/*": [
        "Cross-Origin-Embedder-Policy: require-corp",
        "Cross-Origin-Resource-Policy: same-origin"
      ]
    }
  },
  "inference": {
    "bindings": {
      "db": false,
      "kv": false,
      "storage": false,
      "ai": false
    }
  },
  "head": {
    "titleTemplate": "%s – NAPI-RS",
    "htmlAttrs": {
      "lang": "en",
      "data-theme": "dark"
    },
    "meta": [
      { "name": "og:site_name", "content": "NAPI-RS" },
      { "property": "og:type", "content": "website" },
      { "property": "og:image", "content": "https://napi.rs/img/og-v2.png" },
      { "name": "twitter:card", "content": "summary_large_image" },
      { "name": "twitter:image", "content": "https://napi.rs/img/og-v2.png" }
    ],
    "link": [
      {
        "rel": "icon",
        "type": "image/png",
        "sizes": "32x32",
        "href": "/img/favicon-32x32.png"
      },
      {
        "rel": "icon",
        "type": "image/png",
        "sizes": "16x16",
        "href": "/img/favicon-16x16.png"
      },
      { "rel": "shortcut icon", "href": "/img/favicon.png" }
    ],
    "script": [
      {
        "src": "https://www.googletagmanager.com/gtag/js?id=G-38WMNQBW8F",
        "async": ""
      },
      {
        "innerHTML": "window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-38WMNQBW8F');"
      }
    ]
  },
  "worker": {
    "compatibility_date": "2026-02-24"
  }
}
